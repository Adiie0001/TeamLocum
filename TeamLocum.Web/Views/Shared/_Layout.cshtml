<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TeamLocum</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TeamLocum.Web.styles.css" asp-append-version="true" />
    <style>
        .navbar-brand { font-weight: 700; color: #0d6efd !important; font-size: 1.4rem; }
        .nav-role-badge { font-size: 0.75rem; padding: 2px 8px; border-radius: 12px; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    TeamLocum
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin") || User.IsInRole("Client"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-controller="Bookings" asp-action="Index">Bookings</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-controller="Locums" asp-action="Index">Doctors</a>
                                </li>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-controller="Clients" asp-action="Index">Hospitals</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-controller="Holidays" asp-action="Index">Holidays</a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-warning">
                                    @User.Identity.Name
                                    @if (User.IsInRole("Admin"))
                                    { <span class="badge bg-danger nav-role-badge ms-1">Admin</span> }
                                    else if (User.IsInRole("Client"))
                                    { <span class="badge bg-primary nav-role-badge ms-1">Hospital</span> }
                                    else if (User.IsInRole("Locum"))
                                    { <span class="badge bg-success nav-role-badge ms-1">Doctor</span> }
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index","Home")" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline-light mt-1 ms-1">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="Identity" asp-page="/Account/Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4 py-3">
        <div class="container text-center">
            &copy; 2026 TeamLocum — Healthcare Staffing Platform |
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
